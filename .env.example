SS_MODE=all-in-one
SERVERSENTINEL_CONFIG_DIR=/config
SERVERSENTINEL_SERVERS_DIR=/data/servers
SERVERSENTINEL_SERVERS_DOCKER_VOLUME=serversentinel-minecraft-servers
SERVERSENTINEL_NODE_IMAGE=nl2109/serversentinel:latest
MODRINTH_API_KEY=
PORT=8080
LOG_LEVEL=info

# Node-agent only. Prefer the Add Node flow in the panel, which generates
# short-lived join-token commands with the correct panel URL and data path.
SS_PANEL_URL=
SS_NODE_NAME=
SS_JOIN_TOKEN=
SS_NODE_DATA_DIR=/data
SS_NODE_DOCKER_DATA_DIR=/opt/serversentinel/data
