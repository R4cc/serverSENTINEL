SS_MODE=all-in-one
SERVERSENTINEL_DATA_DIR=/data
SERVERSENTINEL_SERVERS_DOCKER_VOLUME=serversentinel-minecraft-servers
SERVERSENTINEL_NODE_IMAGE=nl2109/serversentinel:latest
SERVERSENTINEL_ENABLE_DEMO=false
VITE_ENABLE_DEMO=false
VITE_SERVERSENTINEL_API_TARGET=http://localhost:8080
MODRINTH_API_KEY=
MCJARS_BASE_URL=https://mcjars.app
MCJARS_API_KEY=
DOCKER_SOCKET=/var/run/docker.sock
PORT=8080
LOG_LEVEL=info
TZ=UTC

# Node-agent only. Node protocol v2 requires these settings in SS_MODE=node.
# Prefer the Add Node flow in the panel, which generates short-lived
# join-token commands with the correct panel URL and host/container data path.
SS_PANEL_URL=
SS_NODE_NAME=
SS_JOIN_TOKEN=
SERVERSENTINEL_DOCKER_DATA_DIR=/opt/serversentinel/data
