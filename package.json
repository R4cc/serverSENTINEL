{
  "name": "serversentinel",
  "version": "1.2.1",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:web": "npm --workspace web run dev",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "test:mobile": "npm run build && node scripts/mobile-ui-smoke.mjs",
    "test:server": "npm --workspace server run test",
    "test:web": "npm --workspace web run test",
    "typecheck": "npm run typecheck --workspaces",
    "demo:reset": "npm --workspace server run demo:reset",
    "screenshots:update": "node scripts/update-readme-screenshots.mjs",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "@fontsource-variable/cascadia-code": "^5.2.2",
    "@fontsource-variable/inter": "^5.2.8",
    "playwright": "1.61.1"
  },
  "overrides": {
    "vite": "^8.1.3",
    "esbuild": "^0.28.1"
  }
}
